*.swp
*.swo
*~

# Node
node_modules/
.npm/

# Logs
logs/
*.log
npm-debug.log*

# Test coverage
coverage/
.nyc_output/

# Pipeline working directory (rebuilt each run)
tmp/

# 11ty build output (built in CI from data/reports/, deployed via actions/deploy-pages)
_site/

# Bot-produced artifacts (reports, memory, feeds snapshot, staging)
# live on the `data` orphan branch, not main. CI hydrates them at
# build time; the pipeline writes them locally at runtime.
/data/

# Local Claude Code settings (machine-specific)
.claude/settings.local.json
.claude/memory/

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx

# Database files (if used for caching)
*.sqlite
*.db
