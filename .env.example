# =====================================================================
# Required — for local dev and manual runs.
#
# In production (Hermes cron), secrets come from the production environment.
# =====================================================================

# GitHub fine-grained PAT scoped to this repo with Contents: read/write.
# Used by Octokit fetchers and for git push in the pipeline.
GITHUB_TOKEN=github_pat_...

# =====================================================================
# Optional
# =====================================================================

# RSSHub single-instance override. In production, leave this unset so
# `config.json → sources.rsshub_urls` supplies the ordered fallback list
# (feeds.js tries each URL per request and falls through on failure).
# Set this only for local debugging against a private instance — it
# disables the fallback list and forces one URL.
# RSSHUB_URL=https://rsshub.pseudoyu.com

# Report date timezone
# REPORT_TIMEZONE=Asia/Taipei

# Override the Claude model used in Stage 2
# CLAUDE_MODEL=claude-opus-4-6

# Host path to the local Hermes Wiki namespace used as bounded cross-day
# context for Stage 3 synthesis. Under Hermes cron the pipeline reads this
# path directly. Set this only if the Wiki lives somewhere other than the
# default path.
# AI_DAILY_REPORT_WIKI_ROOT=/home/bolin8017/Documents/Hermes/Wiki/ai-daily-report

# Allow Stage 2 to run against stale staging data (from a prior day).
# Default: 0 (abort if staging date != today). Set to 1 to override.
# ALLOW_STALE=0

# Skip git push in both stages (also available as --skip-push CLI flag)
# SKIP_PUSH=0

# Minutes the sequencer waits before its single auto-recover retry of a failed
# retryable stage (e.g. synthesize). A transient API 529/overload usually
# outlasts an immediate back-to-back retry, so the one retry waits this long
# first. Default: 30. Set 0 to retry immediately (old behavior).
# AUTORECOVER_RETRY_DELAY_MIN=30

# =====================================================================
# Self-hosted aggregator ingestion (Miniflux + RSSHub)
# =====================================================================

# Miniflux REST API base URL. The pipeline pulls pure-RSS feed items from
# Miniflux (fed by self-hosted RSSHub) once per run, replacing the per-source
# RSS provider chains. Stack: docker/aggregator/docker-compose.yml.
# NOTE: this host's Docker runs {"bridge":"none","iptables":false}, so the
# stack uses host networking and Miniflux binds 127.0.0.1:8080 — reachable
# from a pipeline running on the same host via localhost.
# MINIFLUX_URL=http://localhost:8080

# Auth for the Miniflux API — pick ONE:
#  (a) API key (Miniflux UI -> Settings -> API Keys); sent as X-Auth-Token:
# MINIFLUX_TOKEN=
#  (b) HTTP Basic auth with the admin credentials (no UI step required):
# MINIFLUX_USERNAME=admin
# MINIFLUX_PASSWORD=

# =====================================================================
# Cloud-fallback providers (Tier 2/3 of the fetcher chain)
# =====================================================================

# Firecrawl API key (https://firecrawl.dev). Free tier: ~500 req/month.
# Used as last-resort scrape for sources that can't be reached via RSSHub
# or jina. Leave empty to disable firecrawl tier entirely.
# FIRECRAWL_API_KEY=fc-...

# FIRECRAWL_DISABLED=1 short-circuits firecrawl in any chain — default ON
# for local dev to prevent accidentally burning quota. Production should
# override this to 0 so prod runs can fall back to firecrawl.
FIRECRAWL_DISABLED=1

# JINA_DISABLED=1 short-circuits jina-reader. Jina is free + unmetered,
# so default OFF (enabled) in all environments.
# JINA_DISABLED=0

# =====================================================================
# Theme bundle
# =====================================================================

# Name of the theme directory under themes/ to activate. Switching the
# whole brief to a different persona is `cp -r themes/ai-builder ...`
# + edit + ACTIVE_THEME=<new-name>.
ACTIVE_THEME=ai-builder

# =====================================================================
# Storage hot/cold tuning
# =====================================================================

# Reports newer than HOT_DAYS live on the data branch; older reports
# archive monthly to GitHub Releases. CI hydrates the last HYDRATE_MONTHS
# back into data/reports/ before 11ty pagination at build time.
HOT_DAYS=60
HYDRATE_MONTHS=12

# =====================================================================
# Catalog 精選 section
# =====================================================================

# Star floor + pool sizes live in
# themes/<theme>/sources.yaml -> github_catalog (min_stars default 30000).
# Cross-day dedup ledger: data/seen-repos.json (committed to the data branch).

# =====================================================================
# Leaderboards (評測)
# =====================================================================

# Artificial Analysis Intelligence Index API key (free tier, ~100 req/day):
# https://artificialanalysis.ai -> account -> API. Sent as the `x-api-key`
# header by the leaderboard-artificial-analysis fetcher. Leave empty to
# disable that one board — the fetcher fails soft (returns nothing) so the
# rest of the pipeline is unaffected. All other leaderboards need no key.
# AA_API_KEY=
