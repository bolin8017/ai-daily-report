# =====================================================================
# Required — for local dev and manual runs.
#
# In production, secrets live in ~/.ai-daily-report.env on the VM host
# and are injected into the Docker container via cron-run.sh.
# =====================================================================

# GitHub fine-grained PAT scoped to this repo with Contents: read/write.
# Used by Octokit fetchers and for git push inside the container.
GITHUB_TOKEN=github_pat_...

# =====================================================================
# Optional
# =====================================================================

# RSSHub single-instance override. In production, leave this unset so
# `config.json → sources.rsshub_urls` supplies the ordered fallback list
# (feeds.js tries each URL per request and falls through on failure).
# Set this only for local debugging against a private instance — it
# disables the fallback list and forces one URL.
# RSSHUB_URL=https://rsshub.pseudoyu.com

# Report date timezone
# REPORT_TIMEZONE=Asia/Taipei

# Override the Claude model used in Stage 2
# CLAUDE_MODEL=claude-opus-4-6

# Host path to the local Hermes Wiki namespace used as bounded cross-day
# context for Stage 3 synthesis. In Docker production, cron-run.sh mounts this
# host path into the container and sets AI_DAILY_REPORT_WIKI_ROOT to the
# container path automatically. Set this in ~/.ai-daily-report.env only if the
# host Wiki lives somewhere else.
# AI_DAILY_REPORT_WIKI_ROOT=/home/bolin8017/Documents/Hermes/Wiki/ai-daily-report

# Allow Stage 2 to run against stale staging data (from a prior day).
# Default: 0 (abort if staging date != today). Set to 1 to override.
# ALLOW_STALE=0

# Skip git push in both stages (also available as --skip-push CLI flag)
# SKIP_PUSH=0

# =====================================================================
# Cloud-fallback providers (Tier 2/3 of the fetcher chain)
# =====================================================================

# Firecrawl API key (https://firecrawl.dev). Free tier: ~500 req/month.
# Used as last-resort scrape for sources that can't be reached via RSSHub
# or jina. Leave empty to disable firecrawl tier entirely.
# FIRECRAWL_API_KEY=fc-...

# FIRECRAWL_DISABLED=1 short-circuits firecrawl in any chain — default ON
# for local dev to prevent accidentally burning quota. The VM .env should
# override this to 0 so prod runs can fall back to firecrawl.
FIRECRAWL_DISABLED=1

# JINA_DISABLED=1 short-circuits jina-reader. Jina is free + unmetered,
# so default OFF (enabled) in all environments.
# JINA_DISABLED=0

# =====================================================================
# Theme bundle
# =====================================================================

# Name of the theme directory under themes/ to activate. Switching the
# whole brief to a different persona is `cp -r themes/ai-builder ...`
# + edit + ACTIVE_THEME=<new-name>.
ACTIVE_THEME=ai-builder

# =====================================================================
# Storage hot/cold tuning
# =====================================================================

# Reports newer than HOT_DAYS live on the data branch; older reports
# archive monthly to GitHub Releases. CI hydrates the last HYDRATE_MONTHS
# back into data/reports/ before 11ty pagination at build time.
HOT_DAYS=60
HYDRATE_MONTHS=12
