# =====================================================================
# Required — only for local-dev / manual runs.
#
# In production, the pipeline runs on Anthropic Cloud Runtime (CCR) and
# reads these from the CCR session's configured secrets, not from .env.
# =====================================================================
# GitHub PAT with Contents read/write permission.
# Used by Octokit in the fetchers. For git push, run.sh trusts the host
# credential helper (gh CLI, libsecret, ssh) instead — a stale value here
# would NOT override a working `gh auth login`.
GITHUB_TOKEN=ghp_...

# =====================================================================
# Optional
# =====================================================================
# RSSHub instance. Defaults to the public community instance maintained
# by @pseudoyu. Fallback: https://rsshub.rssforever.com
RSSHUB_URL=https://rsshub.pseudoyu.com

# Report date timezone
REPORT_TIMEZONE=Asia/Taipei
