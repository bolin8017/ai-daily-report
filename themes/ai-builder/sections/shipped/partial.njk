{# 上線 tab — shipped.trending / topic_discovery / dev_watch_taiwan / dev_watch_global #}
<section class="section-shipped tab-panel" id="shipped" role="tabpanel" aria-labelledby="tab-shipped">
  <h2>上線 — 新鮮專案</h2>

  <div class="section-filter" role="radiogroup" aria-label="上線 篩選">
    <button type="button" class="section-chip active" role="radio" aria-checked="true" data-filter="all">全部</button>
    {% if report.shipped.trending and (report.shipped.trending | length) %}<button type="button" class="section-chip" role="radio" aria-checked="false" data-filter="trending">Trending</button>{% endif %}
    {% if report.shipped.topic_discovery and (report.shipped.topic_discovery | length) %}<button type="button" class="section-chip" role="radio" aria-checked="false" data-filter="topic_discovery">Topic Discovery</button>{% endif %}
    {% if report.shipped.dev_watch_taiwan and (report.shipped.dev_watch_taiwan | length) %}<button type="button" class="section-chip" role="radio" aria-checked="false" data-filter="dev_watch_taiwan">🇹🇼 台灣</button>{% endif %}
    {% if report.shipped.dev_watch_global and (report.shipped.dev_watch_global | length) %}<button type="button" class="section-chip" role="radio" aria-checked="false" data-filter="dev_watch_global">🌐 全球</button>{% endif %}
  </div>

  {% if report.shipped.trending and (report.shipped.trending | length) %}
  <div class="sub-section" data-subsection="trending">
    <h3 class="sub-section-title"><span class="sub-title-text">GitHub Trending</span><span class="sub-count">{{ report.shipped.trending | length }} 項</span></h3>
    <ol class="shipped-list">
      {%- for item in report.shipped.trending %}
      {% include "v2/item-card.njk" %}
      {%- endfor %}
    </ol>
  </div>
  {% endif %}

  {% if report.shipped.topic_discovery and (report.shipped.topic_discovery | length) %}
  <div class="sub-section" data-subsection="topic_discovery">
    <h3 class="sub-section-title"><span class="sub-title-text">Topic Discovery — 還沒被發現的</span><span class="sub-count">{{ report.shipped.topic_discovery | length }} 項</span></h3>
    <ol class="shipped-list">
      {%- for item in report.shipped.topic_discovery %}
      {% include "v2/item-card.njk" %}
      {%- endfor %}
    </ol>
  </div>
  {% endif %}

  {% if report.shipped.dev_watch_taiwan and (report.shipped.dev_watch_taiwan | length) %}
  <div class="sub-section" data-subsection="dev_watch_taiwan">
    <h3 class="sub-section-title"><span class="sub-title-text">🇹🇼 Dev Watch 台灣</span><span class="sub-count">{{ report.shipped.dev_watch_taiwan | length }} 項</span></h3>
    <ol class="shipped-list">
      {%- for item in report.shipped.dev_watch_taiwan %}
      {% include "v2/item-card.njk" %}
      {%- endfor %}
    </ol>
  </div>
  {% endif %}

  {% if report.shipped.dev_watch_global and (report.shipped.dev_watch_global | length) %}
  <div class="sub-section" data-subsection="dev_watch_global">
    <h3 class="sub-section-title"><span class="sub-title-text">🌐 Dev Watch 全球</span><span class="sub-count">{{ report.shipped.dev_watch_global | length }} 項</span></h3>
    <ol class="shipped-list">
      {%- for item in report.shipped.dev_watch_global %}
      {% include "v2/item-card.njk" %}
      {%- endfor %}
    </ol>
  </div>
  {% endif %}
</section>
