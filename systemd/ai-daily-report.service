# AI Daily Report — systemd service unit
#
# Runs the two-stage pipeline inside Docker:
#   Stage 1: fetch + condense + commit staging data
#   Stage 2: Claude agent analysis + commit report
#
# Install via scripts/setup-vm.sh, which substitutes __USER__ and
# __REPO_DIR__ with actual values and copies to /etc/systemd/system/.

[Unit]
Description=AI Daily Report — daily tech brief pipeline
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service
OnFailure=ai-daily-report-notify@%n.service

[Service]
Type=oneshot
User=__USER__
ExecStart=__REPO_DIR__/scripts/cron-run.sh

# No start-timeout: Stage 2 (claude -p) runtime varies widely with
# model + prompt size. Capping it at 30 min caused SIGTERM kills on
# slow days. OnFailure still fires for genuine crashes, and the timer
# itself ensures we never overlap runs.
TimeoutStartSec=infinity

# Pipeline timezone — determines the report date (YYYY-MM-DD)
Environment=TZ=Asia/Taipei
Environment=REPORT_TIMEZONE=Asia/Taipei

# Logging → journalctl -u ai-daily-report
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ai-daily-report

# --- Hardening ---
# Restrict filesystem access to the essentials.
# ReadWritePaths allows Docker socket + user home for secrets/config.
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=yes
ReadWritePaths=/var/run/docker.sock __HOME__

# Prevent privilege escalation
NoNewPrivileges=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes

# Only allow socket + network address families (Docker needs AF_UNIX)
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6

# System call filter — only standard service calls
SystemCallArchitectures=native

[Install]
WantedBy=multi-user.target
