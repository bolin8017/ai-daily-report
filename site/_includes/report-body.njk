{# Schema-version routing for archive pages and any legacy include site.
   v2.x unified reports (2 or 2.1) → site/_includes/v2/unified.njk
   v1.x lens reports                → legacy lens/ai-builder.njk (preserves archive rendering)

   2.1 is the post-cutover format produced by editorial+merge; on-disk
   shape matches 2.0 so the same partial renders both.
#}
{% if report and (report.schema_version == 2 or report.schema_version == 2.1) %}
  {% include "v2/unified.njk" %}
{% else %}
  {% include "lens/ai-builder.njk" %}
{% endif %}
