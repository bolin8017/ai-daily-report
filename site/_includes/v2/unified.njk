{# v2.0 layout: 6 function-based tabs + cross-cutting audience filter chips. #}

<nav class="tab-bar" role="tablist" aria-label="報告分區">
  <div class="tab-bar-inner">
    <a href="#signals" class="tab active" role="tab" id="tab-signals" aria-controls="signals" aria-selected="true" tabindex="0" data-tab="signals">訊號</a>
    <a href="#ideation" class="tab" role="tab" id="tab-ideation" aria-controls="ideation" aria-selected="false" tabindex="-1" data-tab="ideation">動手做</a>
    <a href="#shipped" class="tab" role="tab" id="tab-shipped" aria-controls="shipped" aria-selected="false" tabindex="-1" data-tab="shipped">上線</a>
    <a href="#pulse" class="tab" role="tab" id="tab-pulse" aria-controls="pulse" aria-selected="false" tabindex="-1" data-tab="pulse">脈動</a>
    <a href="#market" class="tab" role="tab" id="tab-market" aria-controls="market" aria-selected="false" tabindex="-1" data-tab="market">市場</a>
    <a href="#tech" class="tab" role="tab" id="tab-tech" aria-controls="tech" aria-selected="false" tabindex="-1" data-tab="tech">技術</a>
  </div>
</nav>

<div class="audience-filter" role="group" aria-label="Audience filter">
  <button type="button" class="audience-chip active" aria-pressed="true" data-audience="all">全部</button>
  <button type="button" class="audience-chip" aria-pressed="false" data-audience="general">個人</button>
  <button type="button" class="audience-chip" aria-pressed="false" data-audience="work">工作</button>
</div>

{% include "v2/section-signals.njk" %}
{% include "v2/section-ideation.njk" %}
{% include "v2/section-shipped.njk" %}
{% include "v2/section-pulse.njk" %}
{% include "v2/section-market.njk" %}
{% include "v2/section-tech.njk" %}
