          "mcp",
          "vlm",
          "fine-tuning",
          "web-scraping",
          "local-llm",
          "inference-engine"
        ],
        "rotating": [
          "ocr",
          "vector-database",
          "embedding",
          "evaluation",
          "kv-cache",
          "text-to-speech",
          "speech-to-text",
          "voice-cloning",
