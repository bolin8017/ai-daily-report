        "rotating_per_day": 3,
        "rotation_seed_field": "date"
      },
      "limit_per_topic": 10
    },
    "github_developers": {
      "enabled": true,
      "global_limit": 100,
      "global_min_followers": 1000,
      "regions": [
        {
          "name": "taiwan",
          "locations": ["taiwan", "taipei"],
          "limit": 50,
          "min_followers": 50
        }
      ],
      "new_repo_window_hours": 72
    }
