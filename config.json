{
  "sources": {
    "rsshub_urls": ["https://rsshub.rssforever.com", "https://rsshub.pseudoyu.com"],
    "feeds": [
      {
        "name": "Hacker News",
        "type": "rsshub",
        "route": "/hackernews/index",
        "normalize": "hackernews",
        "category": "community",
        "limit": 30
      },
      {
        "name": "Show HN",
        "type": "rsshub",
        "route": "/hackernews/show",
        "normalize": "hackernews",
        "category": "community",
        "limit": 15
      },
      {
        "name": "Dev.to Top",
        "type": "rsshub",
        "route": "/dev.to/top/week",
        "category": "community",
        "limit": 15
      },
      {
        "name": "Lobsters",
        "type": "json",
        "url": "https://lobste.rs/hottest.json",
        "normalize": "lobsters",
        "category": "community",
        "limit": 15
      },
      {
        "name": "SegmentFault",
        "type": "rss",
        "url": "https://segmentfault.com/feeds",
        "category": "中文社群",
        "limit": 10
      },
      {
        "name": "OSChina",
        "type": "rss",
        "url": "https://www.oschina.net/news/rss",
        "category": "中文社群",
        "limit": 5
      },
      {
        "name": "Changelog",
        "type": "rss",
        "url": "https://changelog.com/feed",
        "category": "community",
        "limit": 10
      },
      {
        "name": "Anthropic News",
        "type": "rsshub",
        "route": "/anthropic/news",
        "category": "AI 公司",
        "limit": 10
      },
      {
        "name": "HuggingFace Daily Papers",
        "type": "rsshub",
        "route": "/huggingface/daily-papers",
        "category": "論文",
        "limit": 15
      },
      {
        "name": "Simon Willison",
        "type": "rss",
        "url": "https://simonwillison.net/atom/everything/",
        "category": "AI 部落格",
        "limit": 10
      },
      {
        "name": "Gary Marcus",
        "type": "rss",
        "url": "https://garymarcus.substack.com/feed",
        "category": "AI 部落格",
        "limit": 5
      },
      {
        "name": "Karpathy",
        "type": "rss",
        "url": "https://karpathy.substack.com/feed",
        "category": "AI 部落格",
        "limit": 5
      },
      {
        "name": "Google AI Blog",
        "type": "rss",
        "url": "https://blog.google/technology/ai/rss",
        "category": "AI 公司",
        "limit": 10
      },
      {
        "name": "Phoronix",
        "type": "rss",
        "url": "https://www.phoronix.com/rss.php",
        "category": "系統/底層",
        "limit": 10
      },
      {
        "name": "LWN",
        "type": "rss",
        "url": "https://lwn.net/headlines/rss",
        "category": "系統/底層",
        "limit": 10
      }
    ],
    "github_topics": {
      "enabled": true,
      "topics": [
        "rag",
        "ocr",
        "llm",
        "agent",
        "vector-database",
        "fine-tuning",
        "web-scraping",
        "mcp",
        "vlm"
      ],
      "limit_per_topic": 10
    },
    "github_developers": {
      "enabled": true,
      "global_limit": 100,
      "global_min_followers": 1000,
      "regions": [
        {
          "name": "taiwan",
          "locations": ["taiwan", "taipei"],
          "limit": 50,
          "min_followers": 50
        }
      ],
      "new_repo_window_hours": 72
    }
  },
  "lenses": [
    {
      "id": "ai-builder",
      "name": "今日 AI",
      "enabled": true,
      "critical": true,
      "prompt_file": ".claude/lenses/ai-builder.md",
      "output_paths": {
        "report": "data/reports/{date}.json",
        "memory": "data/memory.json"
      }
    },
    {
      "id": "phison-aidaptiv",
      "name": "Phison aiDAPTIV+",
      "enabled": true,
      "critical": false,
      "prompt_file": ".claude/lenses/phison-aidaptiv.md",
      "sources_overlay": {
        "feeds": [
          {
            "type": "rss",
            "name": "Phison Blog",
            "url": "https://phisonblog.com/feed/",
            "category": "phison-vendor",
            "limit": 10
          },
          {
            "type": "rss",
            "name": "vLLM Releases",
            "url": "https://github.com/vllm-project/vllm/releases.atom",
            "category": "kv-cache-research",
            "limit": 10
          },
          {
            "type": "rss",
            "name": "LMCache Releases",
            "url": "https://github.com/LMCache/LMCache/releases.atom",
            "category": "kv-cache-research",
            "limit": 10
          },
          {
            "type": "rss",
            "name": "NVIDIA Developer",
            "url": "https://developer.nvidia.com/blog/feed",
            "category": "kv-cache-research",
            "limit": 10
          },
          {
            "type": "rss",
            "name": "SK Hynix News",
            "url": "https://news.skhynix.com/feed/",
            "category": "ssd-vendor",
            "limit": 10
          },
          {
            "type": "rss",
            "name": "BlocksAndFiles",
            "url": "https://blocksandfiles.com/feed/",
            "category": "ssd-vendor",
            "limit": 10
          }
        ],
        "github_topics": {
          "topics": ["kv-cache", "local-llm", "on-device-ai", "llm-app"]
        }
      },
      "rotation": { "starvation_threshold_days": 7 },
      "output_paths": {
        "report": "data/reports/lenses/{id}/{date}.json",
        "memory": "data/memory/{id}.json"
      }
    }
  ],
  "report": {
    "language": "zh-TW",
    "max_featured_items": 12,
    "style": "creative"
  }
}
